{
  "dashboard": {
    "uid": "containers-metrics",
    "title": "🐳 Containers - Docker Metrics",
    "tags": ["infralab", "docker", "containers"],
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "templating": {
      "list": [
        {
          "name": "container",
          "type": "query",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
          "query": "label_values(container_cpu_usage_seconds_total{name!=\"\"}, name)",
          "includeAll": true,
          "multi": true,
          "current": { "selected": true, "text": "All", "value": "$__all" },
          "refresh": 2
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Containers Status",
        "type": "table",
        "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "targets": [{
          "expr": "up",
          "legendFormat": "{{ job }} - {{ instance }}",
          "format": "table",
          "instant": true
        }],
        "transformations": [
          { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true } } }
        ],
        "fieldConfig": {
          "overrides": [{
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{
              "id": "custom.cellOptions",
              "value": { "type": "color-background" }
            }, {
              "id": "mappings",
              "value": [
                { "type": "value", "options": { "1": { "text": "🟢 UP", "color": "green" }, "0": { "text": "🔴 DOWN", "color": "red" } } }
              ]
            }]
          }]
        }
      },
      {
        "id": 2,
        "title": "Container CPU Usage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "targets": [{
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"$container\",name!=\"\"}[5m]) * 100",
          "legendFormat": "{{ name }}"
        }],
        "fieldConfig": {
          "defaults": { "unit": "percent", "custom": { "fillOpacity": 15, "lineWidth": 2, "gradientMode": "scheme" } }
        }
      },
      {
        "id": 3,
        "title": "Container Memory Usage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "targets": [{
          "expr": "container_memory_usage_bytes{name=~\"$container\",name!=\"\"}",
          "legendFormat": "{{ name }}"
        }],
        "fieldConfig": {
          "defaults": { "unit": "bytes", "custom": { "fillOpacity": 15, "lineWidth": 2, "gradientMode": "scheme" } }
        }
      },
      {
        "id": 4,
        "title": "Container Network RX",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "targets": [{
          "expr": "irate(container_network_receive_bytes_total{name=~\"$container\",name!=\"\"}[5m])",
          "legendFormat": "RX {{ name }}"
        }],
        "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 10, "lineWidth": 2 } } }
      },
      {
        "id": 5,
        "title": "Container Network TX",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "targets": [{
          "expr": "irate(container_network_transmit_bytes_total{name=~\"$container\",name!=\"\"}[5m])",
          "legendFormat": "TX {{ name }}"
        }],
        "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 10, "lineWidth": 2 } } }
      },
      {
        "id": 6,
        "title": "Container Disk Read",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "targets": [{
          "expr": "irate(container_fs_reads_bytes_total{name=~\"$container\",name!=\"\"}[5m])",
          "legendFormat": "Read {{ name }}"
        }],
        "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 10, "lineWidth": 2 } } }
      },
      {
        "id": 7,
        "title": "Container Disk Write",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "targets": [{
          "expr": "irate(container_fs_writes_bytes_total{name=~\"$container\",name!=\"\"}[5m])",
          "legendFormat": "Write {{ name }}"
        }],
        "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 10, "lineWidth": 2 } } }
      },
      {
        "id": 8,
        "title": "Container Restart Count",
        "type": "bargauge",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "targets": [{
          "expr": "changes(container_start_time_seconds{name!=\"\"}[1h])",
          "legendFormat": "{{ name }}",
          "instant": true
        }],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 3 }
              ]
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Running Containers",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 30 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "targets": [{ "expr": "count(container_start_time_seconds{name!=\"\"})", "legendFormat": "Running", "instant": true }],
        "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
      },
      {
        "id": 10,
        "title": "Targets Down",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 30 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "targets": [{ "expr": "count(up == 0) or vector(0)", "legendFormat": "Down", "instant": true }],
        "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
      }
    ],
    "schemaVersion": 39
  },
  "overwrite": true
}
